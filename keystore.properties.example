# Copy to keystore.properties and fill in your upload key details.
# keystore.properties is gitignored — do not commit it.
#
# With this file present:
#   .\gradlew.bat bundleRelease   → signed AAB for Google Play (app/release/)
#   .\gradlew.bat assembleRelease → signed release APK
# Without it:
#   .\gradlew.bat assembleRelease → unsigned release APK (e.g. F-Droid builds)
#   .\gradlew.bat bundleRelease   → fails with a clear error

# Path to your .jks or .keystore file (relative to project root, or absolute).
# Use forward slashes on Windows — backslashes are escape characters in .properties files.
storeFile=path/to/upload-keystore.jks

storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password
